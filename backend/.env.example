# App
NODE_ENV=development
PORT=3000
TRUST_PROXY=false
ENABLE_SWAGGER=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=lynk
DB_PASSWORD=replace_with_strong_database_password
DB_NAME=lynk_db
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=lynk-media
CLOUDFRONT_DOMAIN=

# OpenAI
OPENAI_API_KEY=

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (optional, not primary in RDC)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Pi Network
PI_API_KEY=
PI_SANDBOX=true
PI_API_BASE_URL=https://api.minepi.com/v2

# Avadapay
AVADAPAY_API_KEY=
AVADAPAY_BASE_URL=https://api.avadapay.com

# Moneroo
MONEROO_API_KEY=
MONEROO_BASE_URL=https://api.moneroo.io

# Coinbase Commerce
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# Monitoring / Analytics
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# CORS
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081
